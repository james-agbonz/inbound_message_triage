{
  "name": "Inbound Message Triage",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "inbound-triage",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "90772fee-776b-42e0-9287-26dccfeb81af",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        400
      ],
      "webhookId": "6240c596-473a-40e4-a65d-f1b5da7a9748"
    },
    {
      "parameters": {
        "jsCode": "\n// First guardrail: reject bad input before spending an AI call.\nconst body = $json.body ?? $json;\nconst from = (body.from ?? '').toString().trim();\nconst channel = (body.channel ?? '').toString().trim();\nconst message = (body.message ?? '').toString().trim();\n\nconst valid = message.length > 0 && from.length > 0 && channel.length > 0;\n\n// Sandbox-safe hash (no require/crypto). FNV-1a over the meaningful fields.\nfunction hash(str) {\n  let h = 0x811c9dc5;\n  for (let i = 0; i < str.length; i++) {\n    h ^= str.charCodeAt(i);\n    h = (h * 0x01000193) >>> 0;\n  }\n  return h.toString(16).padStart(8, '0');\n}\n\nconst dedupe_hash = valid ? hash(`${from}|${channel}|${message}`) : null;\n\nreturn [{\n  json: {\n    valid,\n    from, channel, message,\n    dedupe_hash,\n    error_note: valid ? null : 'Invalid input: message/from/channel required and non-empty',\n  }\n}];\n"
      },
      "id": "074d6dd2-beb8-4b2b-a883-3d771f3e9a8a",
      "name": "Validate Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        400
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "loose",
            "version": 2
          },
          "conditions": [
            {
              "id": "309cb847-9108-4de7-ad05-271fa3724b05",
              "leftValue": "={{ $json.valid.toBoolean() }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
