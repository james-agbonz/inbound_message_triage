    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key={{ $env.GEMINI_API_KEY }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"You are a support-inbox triage classifier. Classify the message below.\\n\\nFrom: {{ $('Validate Input').item.json.from }}\\nChannel: {{ $('Validate Input').item.json.channel }}\\nMessage: {{ $('Validate Input').item.json.message }}\\n\\nRules for needs_human:\\n- Set TRUE only for: refund requests, complaints, anger/frustration, legal or chargeback threats, cancellations, or anything financially or reputationally risky.\\n- Set FALSE for routine questions a standard reply can handle: pricing, discounts, how-to, scheduling, general info, simple sales questions.\\n- When unsure, prefer FALSE unless the message shows risk or dissatisfaction.\\n\\nOther rules:\\n- urgency: high only for time-sensitive or angry messages; medium for normal requests; low for casual info.\\n- suggested_reply: short, friendly, 1-3 sentences. Never promise a refund outright.\\n- Pick the single best category.\"\n        }\n      ]\n    }\n  ],\n  \"generationConfig\": {\n    \"temperature\": 0.2,\n    \"responseMimeType\": \"application/json\",\n    \"responseSchema\": {\n      \"type\": \"OBJECT\",\n      \"properties\": {\n        \"category\": {\n          \"type\": \"STRING\",\n          \"enum\": [\n            \"billing\",\n            \"access_issue\",\n            \"sales_question\",\n            \"spam\",\n            \"other\"\n          ]\n        },\n        \"urgency\": {\n          \"type\": \"STRING\",\n          \"enum\": [\n            \"low\",\n            \"medium\",\n            \"high\"\n          ]\n        },\n        \"needs_human\": {\n          \"type\": \"BOOLEAN\"\n        },\n        \"suggested_reply\": {\n          \"type\": \"STRING\"\n        }\n      },\n      \"required\": [\n        \"category\",\n        \"urgency\",\n        \"needs_human\",\n        \"suggested_reply\"\n      ]\n    }\n  }\n}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "366664c9-10cf-4218-9eaf-adfd674039fe",
      "name": "Classify (Gemini)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1100,
        240
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "\n// Second guardrail: parse + schema-check the AI response.\n// On ANY problem, fail SAFE: flag for a human rather than drop the message.\nconst SAFE = {\n  category: 'other',\n  urgency: 'high',\n  needs_human: true,\n  suggested_reply: 'Thanks for reaching out \u2014 a team member will follow up with you shortly.',\n};\nconst CATS = ['billing','access_issue','sales_question','spam','other'];\nconst URG  = ['low','medium','high'];\n\nconst base = $('Validate Input').item.json;\nlet ai = null, status = 'processed', error_note = null;\n\ntry {\n  // Gemini returns candidates[0].content.parts[0].text containing JSON (responseMimeType=json)\n  const text = $json?.candidates?.[0]?.content?.parts?.[0]?.text;\n  if (!text) throw new Error('No text in AI response');\n  ai = JSON.parse(text);\n\n  const ok =\n    CATS.includes(ai.category) &&\n    URG.includes(ai.urgency) &&\n    typeof ai.needs_human === 'boolean' &&\n    typeof ai.suggested_reply === 'string' &&\n    ai.suggested_reply.trim().length > 0;\n\n  if (!ok) throw new Error('AI output failed schema validation');\n} catch (e) {\n  ai = SAFE;\n  status = 'ai_fallback';\n  error_note = 'AI fallback: ' + e.message;\n}\n\nreturn [{\n  json: {\n    from: base.from,\n    channel: base.channel,\n    message: base.message,\n    dedupe_hash: base.dedupe_hash,\n    category: ai.category,\n    urgency: ai.urgency,\n    needs_human: ai.needs_human,\n    suggested_reply: ai.suggested_reply,\n    status,\n    error_note,\n  }\n}];\n"
      },
